rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomCode} {
      allow read: if true;
      allow create: if request.resource.data.host is string
                    && request.resource.data.phase == 'lobby';
      allow update: if resource.data.phase != 'ended';
      allow delete: if false;

      match /players/{playerName} {
        allow read: if true;
        allow create, update: if request.resource.data.name is string;
        allow delete: if false;
      }
    }
  }
}
